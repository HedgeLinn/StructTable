# ============================================================
# PDF2json Pipeline Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- LLM Model ---
LLM_URL=http://new-api.mypy.cn/v1/chat/completions
LLM_API_KEY=your-api-key-here
LLM_MODEL=deepseek-v4-pro
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=8192
LLM_TIMEOUT=180
LLM_MAX_RETRIES=2
LLM_WORKERS=5

# --- PDF Converter (ocr_vl | mineru) ---
CONVERTER=ocr_vl

# --- OCR Vision Model (PDF -> Markdown) ---
OCR_URL=http://your-ocr-service:8004/cloud_ai_service/OCR/VL
OCR_PROMPT=请将图片中的表格识别为 HTML <table> 格式...
OCR_DPI=200
OCR_TIMEOUT=300

# --- OCR Batch ---
OCR_BATCH_INPUT_DIR=C:\path\to\input\pdfs
OCR_BATCH_OUTPUT_DIR=C:\path\to\output\markdown
OCR_BATCH_WORKERS=5

# --- MinerU Cloud (PDF -> Markdown) ---
MINERU_TOKEN=your-mineru-token-here
MINERU_URL=https://mineru.net/api/v4
MINERU_MODEL_VERSION=vlm
MINERU_LANGUAGE=ch
MINERU_ENABLE_TABLE=true
MINERU_POLL_INTERVAL=10
MINERU_POLL_MAX=600

# --- MinerU Batch ---
MINERU_BATCH_INPUT_DIR=C:\path\to\input\pdfs
MINERU_BATCH_OUTPUT_DIR=C:\path\to\output\markdown
MINERU_BATCH_WORKERS=3
